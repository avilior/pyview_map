set dotenv-load

host := env("FLIGHTS_HOST", "0.0.0.0")
port := env("FLIGHTS_PORT", "8300")

default:
    @just --list

# Install dependencies
install:
    uv sync

# Run the flights backend
run:
    uv run flights-backend

# Build Docker image
docker-build:
    docker build -t flights-backend .

# Run in Docker (maps external port to internal 80)
docker-run:
    docker run --rm -p {{port}}:80 --env-file .env --name flights-backend flights-backend 2>/dev/null || \
    docker run --rm -p {{port}}:80 --name flights-backend flights-backend

# Stop Docker container
docker-stop:
    docker stop flights-backend 2>/dev/null || true

# Health check
health:
    curl -s http://localhost:{{port}}/api/health | python -m json.tool

# Open API docs
docs:
    open http://localhost:{{port}}/api/docs
